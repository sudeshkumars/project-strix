# ═══════════════════════════════════════════════════════════════
# Stryx — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env for local development.
# On Pterodactyl, set these in the panel Startup tab instead.
# ═══════════════════════════════════════════════════════════════

# ─── REQUIRED ──────────────────────────────────────────────────
BOT_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_application_client_id_here
BOT_OWNER_ID=your_discord_user_id_here

# ─── ENVIRONMENT ──────────────────────────────────────────────
# "development" = deploys slash commands to DEV_GUILD_ID only (instant)
# "production"  = deploys globally (~1hr propagation), silences debug logs
NODE_ENV=development

# ─── DEV ONLY ─────────────────────────────────────────────────
# Guild ID for instant slash command deployment during dev
DEV_GUILD_ID=

# ─── BRANDING (all optional) ──────────────────────────────────
# Display name shown in every V2 card footer and classic embed footer
FOOTER_TEXT=Stryx

# Your Discord support server invite link (appended to footer)
SUPPORT_SERVER=

# Direct image URL for the footer icon (bot avatar or logo)
FOOTER_ICON=

# Banner image URL shown in setup wizard panels
SETUP_BANNER_URL=

# Override footer text specifically for setup panels (defaults to FOOTER_TEXT)
SETUP_FOOTER_TEXT=
